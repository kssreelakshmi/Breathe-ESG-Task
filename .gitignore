node_modules/
dist/
dist-ssr/
.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# VS Code
.vscode/
*.code-workspace


# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

